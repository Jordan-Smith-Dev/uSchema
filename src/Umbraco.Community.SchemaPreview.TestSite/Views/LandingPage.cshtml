@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@Model.Name</title>
    <script type="application/ld+json">
    {
        "@@context": "https://schema.org",
        "@@type": "WebPage",
        "name": "@Model.Name",
        "url": "@Model.Url()",
        "description": "A sample landing page demonstrating structured data for uSchema validation.",
        "breadcrumb": {
            "@@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://example.com"
                },
                {
                    "@@type": "ListItem",
                    "position": 2,
                    "name": "@Model.Name",
                    "item": "@Model.Url()"
                }
            ]
        }
    }
    </script>
</head>
<body>
    <h1>@Model.Name</h1>
    <p>This is a test landing page for uSchema validation.</p>
</body>
</html>
